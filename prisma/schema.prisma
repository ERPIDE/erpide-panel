// erpide-panel database schema.
//
// Migration history: previously user/order/license state lived in a single
// JSON blob (`erpide-state.json`) on Vercel Blob. Hobby-plan advanced-op limit
// kept getting hit on every login, so we moved the hot path to a real DB.
// JSON-shaped sub-records (savedAddresses, items) are kept as Json columns —
// they're never queried independently.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id
  email        String  @unique
  name         String
  surname      String
  passwordHash String

  emailVerified              Boolean   @default(false)
  verificationToken          String?   @unique
  verificationTokenExpiresAt DateTime?

  gsmNumber       String?
  identityNumber  String?
  companyName     String?
  taxNumber       String?
  address         String?
  city            String?
  postalCode      String?
  district        String?

  // Array of SavedAddress — see UserRecord.savedAddresses in user-store.ts.
  savedAddresses Json?

  acceptedTermsAt     DateTime?
  acceptedKvkkAt      DateTime?
  marketingConsentAt  DateTime?

  oauthProvider   String?
  oauthProviderId String?
  avatarUrl       String?

  iyzicoCardUserKey     String?
  iyzicoCardToken       String?
  iyzicoCardLastFour    String?
  iyzicoCardAssociation String?
  iyzicoCardSavedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@unique([oauthProvider, oauthProviderId], name: "oauth_provider_lookup")
  @@index([email])
}

model Order {
  id             String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  // Array of OrderItem — license keys, sku ids, backend provisioning data.
  items          Json
  totalPrice     Float
  currency       String
  paymentId      String?
  conversationId String   @unique
  status         String

  iyzicoToken    String?
  isTrial        Boolean  @default(false)
  trialExpiresAt DateTime?

  subscriptionExpiresAt    DateTime?
  billingCycle             String?
  autoRenewEnabled         Boolean?
  lastRenewAttemptAt       DateTime?
  lastRenewError           String?
  renewedFromOrderId       String?

  cancelledAt              DateTime?
  cancelledBy              String?
  cancellationReason       String?
  expiringSoonEmailSentAt  DateTime?
  renewFailedEmailSentAt   DateTime?

  creditsConsumed          Int?

  createdAt DateTime @default(now())
  paidAt    DateTime?

  @@index([userId])
  @@index([status])
  @@index([isTrial, status])
}

model LicenseCode {
  // Normalized code (uppercase, hyphens preserved) — see normalizeCode().
  code            String   @id
  skuId           String
  productId       String
  durationDays    Int
  batchId         String?
  note            String?

  createdAt       DateTime @default(now())
  expiresAt       DateTime?
  redeemedBy      String?
  redeemedAt      DateTime?
  redeemedOrderId String?

  @@index([batchId])
  @@index([redeemedBy])
}

model BankTransferRequest {
  // HAV-XXXXXXXX format.
  code        String   @id
  userId      String
  userEmail   String
  productId   String
  skuIds      Json
  skuNames    Json?
  amountUSD   Float
  fxRate      Float
  fxRateDate  String
  amountTRY   Float
  ibanUsed    String
  ibanHolder  String
  status      String

  createdAt        DateTime @default(now())
  expiresAt        DateTime
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?
  orderId          String?

  @@index([userId])
  @@index([status])
}

// ── Phase 2: panel auth / pocket / support ────────────────────────
// All these used to live on Vercel Blob (one blob per session, plus a few
// monolithic JSON files). Each login touched Blob's Advanced Ops quota,
// which blew through the Hobby tier in a month. Moved here so Phase 1's
// rate-limit cure stays cured.

model Session {
  token        String   @id
  userId       String
  userType     String
  userName     String
  userEmail    String?
  userRole     String?
  customerCode String?

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model Admin {
  id       String @id
  name     String
  email    String @unique
  password String
  role     String
}

model Customer {
  id           String  @id
  code         String  @unique
  name         String
  password     String
  project      String
  contactEmail String
  contactPhone String?
}

model PocketToken {
  // pkt_<random> prefix from issueToken().
  token      String   @id
  userId     String
  label      String
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model PocketData {
  // One row per user — mobile app overwrites whole `data` blob on sync.
  userId    String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model PocketPushToken {
  // Expo push token is globally unique per device.
  expoPushToken String   @id
  userId        String
  platform      String
  deviceName    String
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime @updatedAt

  @@index([userId])
}

model SupportRequest {
  id            String   @id
  channel       String
  customerName  String?
  customerEmail String?
  summary       String?
  // SupportMessage[] — see lib/support-requests.ts.
  transcript    Json
  meta          Json?
  status        String
  // Vapi call.id — idempotency for end-of-call-report webhook.
  externalId    String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([updatedAt])
}
