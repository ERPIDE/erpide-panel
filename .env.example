# erpide-panel — required + optional environment variables.
#
# Local dev: copy to `.env.local` and fill in. .gitignore already excludes
# both .env.local and .env*.local, so credentials stay out of the repo.
# Production: every variable below also needs to be set in Vercel's project
# Environment Variables page (Production scope at minimum).

# =====================================================================
# Database (Neon Postgres)
# =====================================================================
# Pooled connection string from Neon dashboard. Required.
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/DB?sslmode=require

# =====================================================================
# Authentication & Sessions
# =====================================================================
# iron-session encryption secret. 32+ random chars.
# Generate: openssl rand -base64 32
SESSION_SECRET=
# Optional override for session cookie name (default: erpide_session).
SESSION_COOKIE_NAME=

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# One-shot seed token for /api/auth/seed (bootstrap first admin).
# Rotate or unset once the first admin exists.
ADMIN_BOOTSTRAP_TOKEN=

# Comma-separated emails treated as platform owners (extra audit privileges).
PLATFORM_OWNER_EMAILS=admin@erpide.com

# =====================================================================
# Vercel Blob (task attachments only — JSON state lives in Neon now)
# =====================================================================
# Format: vercel_blob_rw_<storeId>_<rest>. Set in Vercel via Blob store UI.
BLOB_READ_WRITE_TOKEN=

# =====================================================================
# Transactional email (Resend)
# =====================================================================
RESEND_API_KEY=
# Verified domain in Resend.
RESEND_FROM_EMAIL=ERPIDE <no-reply@erpide.com>

# =====================================================================
# Payments — iyzico
# =====================================================================
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=

# =====================================================================
# Payments — bank transfer (havale) fallback
# =====================================================================
BANK_IBAN_TRY=
BANK_HOLDER=ERPİDE Yazılım San. Tic. A.Ş.
# Override the daily USD/TRY conversion rate (optional — defaults to fetch).
USD_TRY_RATE=

# =====================================================================
# AI / Voice
# =====================================================================
# Marketing chat (Eylül) + admin tools.
ANTHROPIC_API_KEY=
# Vapi voice assistant (Bizi Ara).
VAPI_PRIVATE_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# =====================================================================
# Cross-product integrations
# =====================================================================
# CaptchaERPIDE backend (captcha.erpide.com)
CAPTCHA_API_BASE_URL=https://captcha.erpide.com
CAPTCHA_INTERNAL_API_TOKEN=

# FinansERPIDE backend
FINANSERPIDE_API_BASE_URL=
FINANSERPIDE_INVALIDATE_URL=
PANEL_FINANSERPIDE_WEBHOOK_SECRET=

# Shared secrets for license server (multi-product license validation).
LICENSE_SERVICE_SECRET=
LICENSE_SHARED_SECRET=

# =====================================================================
# Cron + GitHub integration
# =====================================================================
# Random secret protecting Vercel cron endpoints.
CRON_SECRET=
# Personal access token for repo automation (read-only is enough).
GITHUB_TOKEN=

# =====================================================================
# Observability — Sentry
# =====================================================================
# DSN is technically public (it's in the client bundle) — safe to commit.
# Get from Sentry project settings.
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map upload (Sentry Settings → Account → API → Auth
# Tokens). Optional locally; required in CI for readable stack traces.
SENTRY_AUTH_TOKEN=

